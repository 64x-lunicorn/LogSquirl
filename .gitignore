# ===========================================================================
# LogSquirl — .gitignore
# ===========================================================================

# ── Build outputs ──────────────────────────────────────────────────────────
build/
build_release/
build_root/
build_root_clang/
build_root_gcc/
build_root_qt5/
build_root_qt6/
compile_commands.json
*.appimage
*.AppImage

# ── Compiled objects and libraries ─────────────────────────────────────────
*.[oa]
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exe
*.out
*.nupkg
*.pdb

# ── Qt auto-generated files ───────────────────────────────────────────────
moc_*.cpp
ui_*.h
qrc_*.cpp
/.moc
/.qmake.stash
/.qmake.cache

# ── CMake ──────────────────────────────────────────────────────────────────
CMakeLists.txt.user*
CMakeUserPresets.json

# ── Editor swap / backup files ─────────────────────────────────────────────
*~
.*.sw?
*.bak
*.tmp
*.orig
*.rej

# ── Visual Studio / VS Code ───────────────────────────────────────────────
/.vs/
/.vscode/
*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates

# ── CLion / JetBrains ─────────────────────────────────────────────────────
.idea/
cmake-build-*/

# ── Xcode ──────────────────────────────────────────────────────────────────
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/

# ── Qt Creator ─────────────────────────────────────────────────────────────
*.pro.user*
*.config
*.creator
*.creator.user
*.files
*.includes

# ── Caches & tool output ──────────────────────────────────────────────────
/.cache/
.ccls-cache/
.clangd/
.cxx/
*.log

# ── macOS ──────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# ── Windows ────────────────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
[Dd]ebug/
[Rr]elease/

# ── Linux ──────────────────────────────────────────────────────────────────
*.swp
*~

# ── Profiling / debug artifacts ───────────────────────────────────────────
massif.out*
core.*
doc/*.html

# ── Packaging artifacts ───────────────────────────────────────────────────
*.deb
*.rpm
*.pkg
*.msi
*.dmg
*.snap

# ── Website (Hugo) ────────────────────────────────────────────────────────
website/public/
website/hugo
website/resources/
build_test_cpp23/

# ── Temporary files ────────────────────────────────────────────────────────
tmp/
