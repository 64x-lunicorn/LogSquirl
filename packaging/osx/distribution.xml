<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>LogSquirl log viewer</title>
    <license file="COPYING"/>
    <welcome file="description.txt"/>
    
    <pkg-ref id="io.github.logsquirl"/>
    <options customize="never" require-scripts="false"/>
    <choices-outline>
        <line choice="default">
            <line choice="io.github.logsquirl"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="io.github.logsquirl" visible="false">
        <pkg-ref id="io.github.logsquirl"/>
    </choice>
    <pkg-ref id="io.github.logsquirl" version="%logsquirl_version%" onConclusion="none">%logsquirl_pkg%</pkg-ref>
</installer-gui-script>
