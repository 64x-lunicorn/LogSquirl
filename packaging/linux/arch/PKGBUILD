# Maintainer: LogSquirl Contributors

pkgname=logsquirl
pkgver=26.03
pkgrel=1
pkgdesc="A multi-platform GUI application that helps browse and search through long and complex log files. It is designed with programmers and system administrators in mind and can be seen as a graphical, interactive combination of grep, less, and tail"
arch=('x86_64')
url='https://github.com/64x-lunicorn/LogSquirl'
license=('GPL3')
provides=('logsquirl')
conflicts=('logsquirl-bin')
depends=('qt6-base' 'hicolor-icon-theme' 'hyperscan' 'xxhash' 'uchardet' 'tbb')
makedepends=('cmake' 'git')

source=("${pkgname}-${pkgver}.tar.gz::https://github.com/64x-lunicorn/LogSquirl/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('TODO')

build() {
    cmake \
        -B "${pkgname}-${pkgver}/build" \
        -S "${pkgname}-${pkgver}" \
        -DCMAKE_BUILD_TYPE='RelWithDebugInfo' \
        -DCMAKE_INSTALL_PREFIX='/usr' \
        -DCPM_USE_LOCAL_PACKAGES=ON \
        -DCPM_SOURCE_CACHE=${srcdir}/cpm_cache \
        -DWARNINGS_AS_ERRORS=OFF \
        -DLOGSQUIRL_USE_SENTRY=OFF \
        -DLOGSQUIRL_BUILD_TESTS=OFF

    make -C "${pkgname}-${pkgver}/build" logsquirl
}

package() {
    make -C "${pkgname}-${pkgver}/build" DESTDIR="$pkgdir" install
    install -D -m644 "${pkgname}-${pkgver}/COPYING" -t "${pkgdir}/usr/share/licenses/${pkgname}"
}